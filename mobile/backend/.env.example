# Copy to .env.local for local dev, and set these in Vercel project env for prod.
# IMPORTANT: use a ROTATED password — the one shared earlier is compromised.

# Full SRV connection string (with the rotated password) — set as a SERVER-SIDE secret only.
MONGODB_URI=mongodb+srv://USER:ROTATED_PASSWORD@cluster0.deqwfb3.mongodb.net/?retryWrites=true&w=majority

# Database name (the URI has no default db). The collection is always "MobileRes".
MONGODB_DB=health_checker

# Shared secret the iOS app sends in the x-api-key header. Pick a long random string.
API_KEY=choose-a-long-random-string
