# macOS
.DS_Store

# ── Xcode project: GENERATED by XcodeGen from project.yml ──
# project.yml is the source of truth — run `xcodegen generate` to recreate.
HealthChecker.xcodeproj/

# ── Xcode build / user state ──
DerivedData/
build/
xcuserdata/
*.xcuserstate
*.xcscmblueprint
*.xccheckout
*.moved-aside

# ── Swift Package Manager ──
.build/
.swiftpm/

# ── CocoaPods / Carthage (if ever added) ──
Pods/
Carthage/Build/

# ── Fastlane (if ever added) ──
fastlane/report.xml
fastlane/Preview.html
fastlane/test_output/
